    "hono": "^4.12.29",
    "koa": "^3.2.1",
    "restify": "^11.1.0",
    "tsup": "^8.0.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@hapi/hapi": "^21.0.0",
    "@tanstack/react-start": "^1.0.0",
    "@sveltejs/kit": "^2.0.0",
    "elysia": "^1.0.0",
    "express": "^4.18.0 || ^5.0.0",
    "fastify": "^4.0.0",
    "hono": "^4.12.29",
    "koa": "^2.14.0",
    "remix": "^2.0.0",
    "restify": "^11.0.0"
