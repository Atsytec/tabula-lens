    "nextjs",
    "remix",
    "sveltekit",
    "tanstack",
    "hono",
    "elysia",
    "pagination",
    "sorting",
    "filtering"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --ext .ts",
    "check-types": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "knex": "^3.0.0",
    "pg": "^8.11.0"
  },
