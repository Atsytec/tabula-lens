{
  "name": "@tabula-lens/node",
  "version": "0.1.0",
  "private": false,
  "description": "Node.js backend SDK for Tabula Lens",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --ext .ts",
    "check-types": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "knex": "^3.0.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@hapi/hapi": "^21.4.9",
    "@types/express": "^4.17.0",
    "@types/koa": "^2.13.0",
    "@types/node": "^20.0.0",
    "@types/restify": "^8.5.0",
    "fastify": "^5.10.0",
    "koa": "^3.2.1",
    "restify": "^11.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@hapi/hapi": "^21.0.0",
    "express": "^4.18.0",
    "fastify": "^4.0.0",
    "koa": "^2.14.0",
    "restify": "^11.0.0"
  }
}
